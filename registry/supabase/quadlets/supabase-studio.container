[Unit]
Description=Supabase Studio
StartLimitIntervalSec=60
StartLimitBurst=3
Requires=supabase.network
After=supabase.network

[Container]
ContainerName=supabase-studio
Image=docker.io/supabase/studio:2025.12.17-sha-43f4f7f
Network=supabase.network:alias=studio
Environment=PORT=3000
Pull=never
EnvironmentFile=%h/.local/share/ryra/supabase/.env

[Service]
EnvironmentFile=%h/.local/share/ryra/supabase/.env
Restart=always
RestartSec=5
TimeoutStartSec=300

[Install]
WantedBy=default.target
