[Unit]
Description=Authelia SSO server
StartLimitIntervalSec=60
StartLimitBurst=3

[Container]
Image=docker.io/authelia/authelia:4.39
AutoUpdate=registry
ContainerName=authelia
Network=authelia.network
PublishPort=${PORT_HTTP}:9091
Volume=%h/services/authelia/config:/config:Z
Pull=missing
EnvironmentFile=%h/services/authelia/.env
HealthCmd=wget -q --spider http://localhost:9091/api/health || exit 1

[Service]
EnvironmentFile=%h/services/authelia/.env
Restart=always
RestartSec=5
TimeoutStartSec=300
ExecStartPre=/bin/bash %h/services/authelia/configs/scripts/generate-config.sh
ExecStartPre=/bin/bash %h/services/authelia/configs/scripts/generate-users.sh
ExecStartPre=/bin/bash %h/services/authelia/configs/scripts/generate-oidc-rsa-key.sh

[Install]
WantedBy=default.target
