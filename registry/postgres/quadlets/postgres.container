[Unit]
Description=Postgres
StartLimitIntervalSec=60
StartLimitBurst=3

[Container]
ContainerName=postgres
Image=docker.io/library/postgres:17-alpine
PublishPort=${RYRA_PORT_TCP}:5432
Volume=postgres-data.volume:/var/lib/postgresql/data:U
Pull=missing
EnvironmentFile=%h/.local/share/ryra/postgres/.env
HealthCmd=pg_isready -U ${POSTGRES_USER:-postgres} || exit 1

[Service]
EnvironmentFile=%h/.local/share/ryra/postgres/.env
Restart=always
RestartSec=5
TimeoutStartSec=300

[Install]
WantedBy=default.target
