[Unit]
Description=Forgejo git forge
StartLimitIntervalSec=60
StartLimitBurst=3
Requires=forgejo-postgres.service
After=forgejo-postgres.service

[Container]
Image=codeberg.org/forgejo/forgejo:11
AutoUpdate=registry
ContainerName=forgejo
Network=forgejo.network
PublishPort=${SERVICE_PORT_HTTP}:3000
Volume=%h/.local/share/services/forgejo/data:/data:Z,U
Pull=missing
EnvironmentFile=%h/.local/share/services/forgejo/.env
HealthCmd=curl -sf http://localhost:3000/api/v1/settings/api || exit 1

[Service]
EnvironmentFile=%h/.local/share/services/forgejo/.env
Restart=always
RestartSec=5
TimeoutStartSec=300
ExecStartPost=/bin/bash %h/.local/share/services/forgejo/configs/scripts/register-oidc.sh

[Install]
WantedBy=default.target
