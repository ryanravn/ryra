[Unit]
Description=Forgejo PostgreSQL database
StartLimitIntervalSec=0
Requires=forgejo.network
After=forgejo.network

[Container]
Image=docker.io/library/postgres:17-alpine
ContainerName=postgres
Network=forgejo.network
Volume=forgejo-db-data.volume:/var/lib/postgresql/data:U
Pull=never
EnvironmentFile=__RYRA_SERVICE_HOME__/.env

[Service]
EnvironmentFile=__RYRA_SERVICE_HOME__/.env
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
