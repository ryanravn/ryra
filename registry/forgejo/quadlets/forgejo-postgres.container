[Unit]
Description=Forgejo PostgreSQL database
StartLimitIntervalSec=60
StartLimitBurst=3
Requires=forgejo.network
After=forgejo.network

[Container]
Image=docker.io/library/postgres:17-alpine
ContainerName=forgejo-postgres
Network=forgejo.network:alias=postgres
Volume=forgejo-db-data.volume:/var/lib/postgresql/data:U
Pull=never
EnvironmentFile=%h/.local/share/ryra/forgejo/.env

[Service]
EnvironmentFile=%h/.local/share/ryra/forgejo/.env
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
