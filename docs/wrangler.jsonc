{
  // Cloudflare Workers Static Assets: serve the Astro docs build (`dist/`) with
  // no Worker script. In Cloudflare, set this project's root directory to
  // `docs`. Build with `bun run build`, deploy with `npx wrangler deploy`. The
  // custom domain (docs.ryra.dev) is bound in the dashboard (Domains tab).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ryra-docs",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist"
  }
}
