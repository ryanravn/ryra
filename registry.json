          "env": {}
        },
        {
          "name": "data-dir-created",
          "run": "test -d $HOME/.local/share/ryra/openclaw",
          "timeout": 30,
          "env": {}
        }
      ],
      "post_start": []
    },
    "postgres": {
      "service": {
        "name": "postgres",
        "description": "PostgreSQL - open source relational database",
        "url": "https://www.postgresql.org/docs/",
        "image": "docker.io/library/postgres:17-alpine",
        "command": null,
        "kind": "infrastructure",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 128,
          "recommended": 256
        }
      },
