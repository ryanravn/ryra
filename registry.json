      "requires": [],
      "mappings": {
        "smtp": {},
        "auth": {
          "OAUTHLIB_INSECURE_TRANSPORT": "1",
          "OAUTH_CLIENT_ID": "{{auth.client_id}}",
          "OAUTH_CLIENT_SECRET": "{{auth.client_secret}}",
          "OAUTH_ISSUER_URL": "{{auth.issuer}}",
          "OAUTH_REDIRECT_URL": "{{service.url}}/auth/login"
        }
      },
      "integrations": {
        "auth": [
          "oidc"
        ],
        "smtp": false
      }
