        },
        {
          "name": "DB_HOST",
          "value": "mariadb",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "DB_ROOT_PASSWD",
          "value": "{{secret.mysql_root_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "SEAFILE_SERVER_HOSTNAME",
          "value": "{{service.domain}}",
