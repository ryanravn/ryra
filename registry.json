        {
          "name": "FORGEJO__database__NAME",
          "value": "forgejo",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__database__USER",
          "value": "forgejo",
          "kind": "default",
          "prompt": null,
