        }
      },
      "ports": [
        {
          "name": "http",
          "container_port": 3000,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "name": "data",
          "mount_path": "/data",
          "host_path": null
        }
      ],
      "env": [
