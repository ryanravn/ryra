{
  "services": {
    "authelia": {
      "service": {
        "name": "authelia",
        "description": "Authelia - lightweight SSO and 2FA server",
        "url": "https://www.authelia.com/",
        "kind": "application",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 128,
          "recommended": 256
        }
      },
      "ports": [
        {
          "name": "http",
          "container_port": 9091,
          "host_port": null,
          "protocol": "tcp"
        }
      ],
      "env": [
        {
          "name": "AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET",
          "value": "{{secret.jwt_secret}}",
          "kind": "default",
          "prompt": null,
          "format": "hex",
          "length": 64
        },
        {
          "name": "AUTHELIA_SESSION_SECRET",
          "value": "{{secret.session_secret}}",
          "kind": "default",
          "prompt": null,
          "format": "hex",
          "length": 64
        },
        {
          "name": "AUTHELIA_STORAGE_ENCRYPTION_KEY",
          "value": "{{secret.storage_key}}",
          "kind": "default",
          "prompt": null,
          "format": "hex",
          "length": 64
        },
        {
          "name": "X_AUTHELIA_CONFIG_FILTERS",
          "value": "template",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHELIA_ADMIN_USER",
          "value": "admin",
          "kind": "prompted",
          "prompt": "Admin username",
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHELIA_ADMIN_PASSWORD",
          "value": "",
          "kind": "required",
          "prompt": "Admin password",
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHELIA_ADMIN_EMAIL",
          "value": "admin@localhost",
          "kind": "prompted",
          "prompt": "Admin email",
          "format": "string",
          "length": null
        },
        {
          "name": "RYRA_DOMAIN",
          "value": "{{ service.domain | default('localhost') }}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "RYRA_AUTH_PORT",
          "value": "9091",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "mappings": {
        "smtp": {},
        "auth": {}
      },
      "integrations": {
        "auth": [],
        "smtp": false
      }
    },
    "caddy": {
      "service": {
        "name": "caddy",
        "description": "Caddy - automatic HTTPS reverse proxy",
        "url": "https://caddyserver.com",
        "kind": "application",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": null,
      "ports": [
        {
          "name": "http",
          "container_port": 80,
          "host_port": 8080,
          "protocol": "tcp"
        },
        {
          "name": "https",
          "container_port": 8443,
          "host_port": 8443,
          "protocol": "tcp"
        }
      ],
      "env": [],
      "requires": [],
      "mappings": {
        "smtp": {},
        "auth": {}
      },
      "integrations": {
        "auth": [],
        "smtp": false
      }
    },
    "forgejo": {
      "service": {
        "name": "forgejo",
        "description": "Forgejo - self-hosted Git forge",
        "url": "https://forgejo.org/docs/",
        "kind": "application",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 256,
          "recommended": 512
        }
      },
      "ports": [
        {
          "name": "http",
          "container_port": 3000,
          "host_port": null,
          "protocol": "tcp"
        }
      ],
      "env": [
        {
          "name": "POSTGRES_USER",
          "value": "forgejo",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "{{secret.db_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_DB",
          "value": "forgejo",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__database__DB_TYPE",
          "value": "postgres",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__database__HOST",
          "value": "postgres:5432",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__database__NAME",
          "value": "forgejo",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__database__USER",
          "value": "forgejo",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__database__PASSWD",
          "value": "{{secret.db_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__server__DOMAIN",
          "value": "localhost",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__server__ROOT_URL",
          "value": "{{service.external_url}}/",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__service__DISABLE_REGISTRATION",
          "value": "true",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "FORGEJO__security__INSTALL_LOCK",
          "value": "true",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "mappings": {
        "smtp": {},
        "auth": {
          "FORGEJO__oauth2_client__ENABLE_AUTO_REGISTRATION": "true",
          "FORGEJO__oauth2_client__ENABLE_OPENID_CONNECT_INSECURE_SKIP_VERIFY": "true",
          "FORGEJO__oauth2_client__OPENID_CONNECT_SCOPES": "openid email profile",
          "FORGEJO__openid__ENABLE_OPENID_SIGNIN": "true",
          "FORGEJO__service__ENABLE_OPENID_SIGNIN": "true",
          "OIDC_AUTH_URL": "{{auth.internal_url}}/api/oidc/authorization",
          "OIDC_CLIENT_ID": "{{auth.client_id}}",
          "OIDC_CLIENT_SECRET": "{{auth.client_secret}}",
          "OIDC_DISCOVERY_URL": "{{auth.internal_url}}/.well-known/openid-configuration",
          "OIDC_PROFILE_URL": "{{auth.internal_url}}/api/oidc/userinfo",
          "OIDC_TOKEN_URL": "{{auth.internal_url}}/api/oidc/token"
        }
      },
      "integrations": {
        "auth": [
          "oidc"
        ],
        "smtp": false
      }
    },
    "immich": {
