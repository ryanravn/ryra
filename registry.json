          "format": "string",
          "length": null
        },
        {
          "name": "INIT_IMMICH_ADMIN_EMAIL",
          "value": "{{admin.email | default('admin@localhost')}}",
          "kind": "prompted",
          "prompt": "Admin email",
          "format": "string",
          "length": null
        },
        {
          "name": "INIT_IMMICH_ADMIN_PASSWORD",
          "value": "{{secret.admin_password}}",
          "kind": "prompted",
          "prompt": "Admin password",
          "format": "string",
          "length": null
        }
