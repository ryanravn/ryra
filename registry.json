{
  "services": {
    "affine": {
      "service": {
        "name": "affine",
        "description": "AFFiNE - privacy-focused knowledge base",
        "url": "https://affine.pro/",
        "image": "ghcr.io/toeverything/affine:stable",
        "command": null,
        "kind": "application",
        "architecture": [
          "amd64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 512,
          "recommended": 1024
        }
      },
      "ports": [
        {
          "name": "http",
          "container_port": 3010,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "name": "config",
          "mount_path": "/root/.affine/config",
          "host_path": null
        },
        {
          "name": "storage",
          "mount_path": "/root/.affine/storage",
          "host_path": null
        }
      ],
      "env": [
        {
          "name": "POSTGRES_USER",
          "value": "affine",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "{{secret.db_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_DB",
          "value": "affine",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "REDIS_SERVER_HOST",
          "value": "redis",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "DATABASE_URL",
          "value": "postgresql://affine:{{secret.db_password}}@postgres:5432/affine",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AFFINE_SERVER_HOST",
          "value": "0.0.0.0",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AFFINE_SERVER_PORT",
          "value": "3010",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AFFINE_INDEXER_ENABLED",
          "value": "false",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "nginx": {
        "upstream_port": "http"
      },
      "containers": [
        {
          "name": "postgres",
          "image": "docker.io/library/postgres:17-alpine",
          "command": null,
          "volumes": [
            {
              "name": "db-data",
              "mount_path": "/var/lib/postgresql/data",
              "host_path": null
            }
          ],
          "env_file": true,
          "depends_on": [],
          "healthcheck": {
            "command": "pg_isready -d $POSTGRES_DB -U $POSTGRES_USER",
            "start_period": 20,
            "interval": 30,
            "retries": 5,
            "timeout": 5
          },
          "init": false
        },
        {
          "name": "redis",
          "image": "docker.io/library/redis:7-alpine",
          "command": null,
          "volumes": [],
          "env_file": true,
          "depends_on": [],
          "healthcheck": {
            "command": "redis-cli --raw incr ping",
            "start_period": 20,
            "interval": 30,
            "retries": 5,
            "timeout": 3
          },
          "init": false
        },
        {
          "name": "migration",
          "image": "ghcr.io/toeverything/affine:stable",
          "command": "sh -c 'node ./scripts/self-host-predeploy.js'",
          "volumes": [
            {
              "name": "config",
              "mount_path": "/root/.affine/config",
              "host_path": null
            },
            {
              "name": "storage",
              "mount_path": "/root/.affine/storage",
              "host_path": null
            }
          ],
          "env_file": true,
          "depends_on": [
            "postgres",
            "redis"
          ],
          "healthcheck": null,
          "init": true
        }
      ],
      "mappings": {
        "smtp": {},
        "auth": {
          "OAUTH_OIDC_CLIENT_ID": "{{auth.client_id}}",
          "OAUTH_OIDC_CLIENT_SECRET": "{{auth.client_secret}}",
          "OAUTH_OIDC_ENABLED": "true",
          "OAUTH_OIDC_ISSUER": "{{auth.url}}/application/o/affine/"
        }
      },
      "integrations": {
        "auth": [
          "oidc"
        ],
        "smtp": false
      },
      "tests": [
        {
          "name": "affine-responds",
          "run": "for i in $(seq 1 30); do curl -sf http://127.0.0.1:$RYRA_PORT_HTTP && exit 0; sleep 2; done; exit 1",
          "timeout": 90,
          "env": {}
        }
      ],
      "post_start": []
    },
    "authentik": {
      "service": {
        "name": "authentik",
        "description": "Authentik - identity provider with SSO and OIDC",
        "url": "https://docs.goauthentik.io/",
        "image": "ghcr.io/goauthentik/server:2025.2",
        "command": "server",
        "kind": "infrastructure",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 512,
          "recommended": 1024
        }
      },
      "ports": [
        {
          "name": "http",
          "container_port": 9000,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "name": "media",
          "mount_path": "/media",
          "host_path": null
        },
        {
          "name": "templates",
          "mount_path": "/templates",
          "host_path": null
        },
        {
          "name": "blueprints",
          "mount_path": "/blueprints/custom",
          "host_path": "%h/blueprints"
        }
      ],
      "env": [
        {
          "name": "AUTHENTIK_SECRET_KEY",
          "value": "{{secret.secret_key}}",
          "kind": "default",
          "prompt": null,
          "format": "hex",
          "length": 50
        },
        {
          "name": "AUTHENTIK_BOOTSTRAP_TOKEN",
          "value": "{{secret.bootstrap_token}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_BOOTSTRAP_EMAIL",
          "value": "",
          "kind": "required",
          "prompt": "Admin email",
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_BOOTSTRAP_PASSWORD",
          "value": "",
          "kind": "required",
          "prompt": "Admin password",
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_USER",
          "value": "authentik",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "{{secret.db_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_DB",
          "value": "authentik",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_REDIS__HOST",
          "value": "redis",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_POSTGRESQL__HOST",
          "value": "postgres",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_POSTGRESQL__USER",
          "value": "authentik",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_POSTGRESQL__NAME",
          "value": "authentik",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "AUTHENTIK_POSTGRESQL__PASSWORD",
          "value": "{{secret.db_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "nginx": {
        "upstream_port": "http"
      },
      "containers": [
        {
          "name": "worker",
          "image": "ghcr.io/goauthentik/server:2025.2",
          "command": "worker",
          "volumes": [
            {
              "name": "media",
              "mount_path": "/media",
              "host_path": null
            },
            {
              "name": "templates",
              "mount_path": "/templates",
              "host_path": null
            },
            {
              "name": "blueprints",
              "mount_path": "/blueprints/custom",
              "host_path": "%h/blueprints"
            }
          ],
          "env_file": true,
          "depends_on": [
            "postgres",
            "redis"
          ],
          "healthcheck": null,
          "init": false
        },
        {
          "name": "postgres",
          "image": "docker.io/library/postgres:17-alpine",
          "command": null,
          "volumes": [
            {
              "name": "db-data",
              "mount_path": "/var/lib/postgresql/data",
              "host_path": null
            }
          ],
          "env_file": true,
          "depends_on": [],
          "healthcheck": {
            "command": "pg_isready -d $POSTGRES_DB -U $POSTGRES_USER",
            "start_period": 20,
            "interval": 30,
            "retries": 5,
            "timeout": 5
          },
          "init": false
        },
        {
          "name": "redis",
          "image": "docker.io/library/redis:7-alpine",
          "command": "--save 60 1 --loglevel warning",
          "volumes": [
            {
              "name": "redis-data",
              "mount_path": "/data",
              "host_path": null
            }
          ],
          "env_file": true,
          "depends_on": [],
          "healthcheck": {
            "command": "redis-cli ping | grep PONG",
            "start_period": 20,
            "interval": 30,
            "retries": 5,
            "timeout": 3
          },
          "init": false
        }
      ],
      "mappings": {
        "smtp": {},
        "auth": {}
      },
      "integrations": {
        "auth": [],
        "smtp": false
      },
      "tests": [
        {
          "name": "authentik-responds",
          "run": "for i in $(seq 1 60); do curl -sf http://127.0.0.1:$RYRA_PORT_HTTP/if/flow/initial-setup/ && exit 0; sleep 2; done; exit 1",
          "timeout": 180,
          "env": {
            "AUTHENTIK_BOOTSTRAP_EMAIL": "admin@test.local",
            "AUTHENTIK_BOOTSTRAP_PASSWORD": "testpassword123"
          }
        },
        {
          "name": "user-created",
          "run": "id authentik",
          "timeout": 30,
          "env": {
            "AUTHENTIK_BOOTSTRAP_EMAIL": "admin@test.local",
            "AUTHENTIK_BOOTSTRAP_PASSWORD": "testpassword123"
          }
        }
      ],
      "post_start": []
    },
    "forgejo": {
