    "seafile": {
      "service": {
        "name": "seafile",
        "description": "Seafile - file sync and share server",
        "url": "https://www.seafile.com/",
        "image": "docker.io/seafileltd/seafile-mc:12.0-latest",
        "command": null,
        "kind": "application",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 512,
          "recommended": 1024
        }
      },
      "ports": [
        {
          "name": "http",
          "container_port": 80,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "name": "data",
          "mount_path": "/shared",
          "host_path": "%h/shared"
        }
      ],
      "env": [
        {
          "name": "MYSQL_ROOT_PASSWORD",
          "value": "{{secret.mysql_root_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "MYSQL_LOG_CONSOLE",
          "value": "true",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "DB_HOST",
          "value": "mariadb",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "DB_ROOT_PASSWD",
          "value": "{{secret.mysql_root_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "SEAFILE_SERVER_HOSTNAME",
          "value": "{% if service.domain %}{{service.domain}}{% else %}localhost{% endif %}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "SEAFILE_SERVER_PROTOCOL",
          "value": "https",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "JWT_PRIVATE_KEY",
          "value": "{{secret.jwt_key}}",
          "kind": "default",
          "prompt": null,
          "format": "hex",
          "length": 32
        },
        {
          "name": "INIT_SEAFILE_ADMIN_EMAIL",
          "value": "",
          "kind": "required",
          "prompt": "Seafile admin email",
          "format": "string",
          "length": null
        },
        {
          "name": "INIT_SEAFILE_ADMIN_PASSWORD",
          "value": "",
          "kind": "required",
          "prompt": "Seafile admin password",
          "format": "string",
          "length": null
        },
        {
          "name": "CACHE_PROVIDER",
          "value": "redis",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "nginx": {
        "upstream_port": "http"
      },
      "containers": [
        {
          "name": "mariadb",
          "image": "docker.io/library/mariadb:10.11",
          "command": null,
          "volumes": [
            {
              "name": "db-data",
              "mount_path": "/var/lib/mysql",
              "host_path": null
            }
          ],
          "env_file": true,
          "depends_on": [],
          "healthcheck": {
            "command": "healthcheck.sh --connect --innodb_initialized",
            "start_period": 20,
            "interval": 30,
            "retries": 5,
            "timeout": 5
          },
          "init": false
        },
        {
          "name": "redis",
          "image": "docker.io/library/redis:7-alpine",
          "command": null,
          "volumes": [],
          "env_file": false,
          "depends_on": [],
          "healthcheck": {
            "command": "redis-cli ping | grep PONG",
            "start_period": 20,
            "interval": 30,
            "retries": 5,
            "timeout": 3
          },
          "init": false
        }
      ],
      "mappings": {
        "smtp": {},
        "auth": {
          "OAUTH_CLIENT_ID": "{{auth.client_id}}",
          "OAUTH_CLIENT_SECRET": "{{auth.client_secret}}",
          "OAUTH_PROVIDER_DOMAIN": "{{auth.url}}",
          "OAUTH_REDIRECT_URL": "https://{{service.domain}}/oauth/callback/"
        }
      },
      "integrations": {
        "auth": [
          "oidc"
        ],
        "smtp": false
      },
      "tests": [
        {
          "name": "seafile-responds",
          "run": "for i in $(seq 1 120); do curl -so /dev/null -w '%{http_code}' http://127.0.0.1:$RYRA_PORT_HTTP 2>/dev/null | grep -qE '^(200|301|302)' && exit 0; sleep 5; done; exit 1",
          "timeout": 660,
          "env": {
            "INIT_SEAFILE_ADMIN_EMAIL": "admin@test.local",
            "INIT_SEAFILE_ADMIN_PASSWORD": "testpassword123",
            "SEAFILE_SERVER_HOSTNAME": "seafile.test.local"
          }
        },
        {
          "name": "user-created",
          "run": "id seafile",
          "timeout": 30,
          "env": {
            "INIT_SEAFILE_ADMIN_EMAIL": "admin@test.local",
            "INIT_SEAFILE_ADMIN_PASSWORD": "testpassword123",
            "SEAFILE_SERVER_HOSTNAME": "seafile.test.local"
          }
        }
      ],
      "post_start": [
        {
          "name": "inject-seafile-oauth",
          "run": "[ -z \"$OAUTH_CLIENT_ID\" ] && exit 0\n\nCONF=/var/lib/seafile/shared/seafile/conf\n\n# Wait for Seafile bootstrap to create seahub_settings.py on the bind-mounted volume\necho \"Waiting for Seafile to initialize...\"\nfor i in $(seq 1 180); do\n  [ -f \"$CONF/seahub_settings.py\" ] && break\n  sleep 2\ndone\n[ -f \"$CONF/seahub_settings.py\" ] || { echo \"seahub_settings.py not found after 360s\"; exit 1; }\n\n# Write the OAuth Python config alongside seahub_settings.py\ncat > \"$CONF/seahub_settings_oauth.py\" << EOF\nENABLE_OAUTH = True\nOAUTH_CREATE_UNKNOWN_USER = True\nOAUTH_ACTIVATE_USER_AFTER_CREATION = True\nOAUTH_CLIENT_ID = \"$OAUTH_CLIENT_ID\"\nOAUTH_CLIENT_SECRET = \"$OAUTH_CLIENT_SECRET\"\nOAUTH_REDIRECT_URL = \"$OAUTH_REDIRECT_URL\"\nOAUTH_PROVIDER_DOMAIN = \"$OAUTH_PROVIDER_DOMAIN\"\nOAUTH_PROVIDER = \"authentik\"\nOAUTH_AUTHORIZATION_URL = \"${OAUTH_PROVIDER_DOMAIN}/application/o/authorize/\"\nOAUTH_TOKEN_URL = \"${OAUTH_PROVIDER_DOMAIN}/application/o/token/\"\nOAUTH_USER_INFO_URL = \"${OAUTH_PROVIDER_DOMAIN}/application/o/userinfo/\"\nOAUTH_SCOPE = [\"openid\", \"profile\", \"email\"]\nOAUTH_ATTRIBUTE_MAP = {\"email\": (True, \"contact_email\"), \"name\": (False, \"name\"), \"sub\": (False, \"uid\")}\nEOF\nchown seafile:seafile \"$CONF/seahub_settings_oauth.py\"\n\n# Append import line if not already present\ngrep -q seahub_settings_oauth \"$CONF/seahub_settings.py\" || echo \"exec(open('/shared/seafile/conf/seahub_settings_oauth.py').read())\" >> \"$CONF/seahub_settings.py\"\n\necho \"OAuth config injected into seahub_settings.py\"\n",
          "timeout": 420
        }
      ]
    },
