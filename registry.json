      },
      "tests": [
        {
          "name": "forgejo-responds",
          "run": "for i in $(seq 1 30); do curl -sf http://127.0.0.1:$RYRA_PORT_HTTP && exit 0; sleep 2; done; exit 1",
          "timeout": 90,
          "env": {}
        },
        {
          "name": "postgres-not-on-localhost",
          "run": "! ss -tlnp | grep -q ':5432 '",
          "timeout": 5,
          "env": {}
        },
        {
          "name": "user-created",
          "run": "id forgejo",
          "timeout": 30,
          "env": {}
        }
      ],
      "post_start": []
    },
    "openclaw": {
      "service": {
        "name": "openclaw",
        "description": "OpenClaw - self-hosted AI assistant gateway",
        "url": "https://docs.openclaw.ai/",
        "image": "ghcr.io/openclaw/openclaw:2026.3.13-1",
        "command": "sh -c \"echo '{\\\"gateway\\\":{\\\"mode\\\":\\\"local\\\",\\\"bind\\\":\\\"lan\\\",\\\"controlUi\\\":{\\\"dangerouslyAllowHostHeaderOriginFallback\\\":true}}}' > /home/node/.openclaw/openclaw.json && exec node openclaw.mjs gateway --allow-unconfigured\"",
        "kind": "application",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 1024,
          "recommended": 2048
        }
      },
      "ports": [
        {
          "name": "gateway",
          "container_port": 18789,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "name": "config",
          "mount_path": "/home/node/.openclaw",
          "host_path": null
        }
      ],
      "env": [
        {
          "name": "OPENCLAW_GATEWAY_TOKEN",
          "value": "{{secret.gateway_token}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "value": "",
          "kind": "prompted",
          "prompt": "Anthropic API key (leave empty to skip)",
          "format": "string",
          "length": null
        },
        {
          "name": "OPENAI_API_KEY",
          "value": "",
          "kind": "prompted",
          "prompt": "OpenAI API key (leave empty to skip)",
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "nginx": {
        "upstream_port": "gateway"
      },
      "containers": [],
      "mappings": {
        "smtp": {},
        "auth": {}
      },
      "integrations": {
        "auth": [],
        "smtp": false
      },
      "tests": [
        {
          "name": "http-responds",
          "run": "for i in $(seq 1 30); do curl -sf http://127.0.0.1:$RYRA_PORT_GATEWAY && exit 0; sleep 2; done; exit 1",
          "timeout": 90,
          "env": {}
        },
        {
          "name": "user-created",
          "run": "id openclaw",
          "timeout": 30,
          "env": {}
        }
      ],
      "post_start": []
    },
    "postgres": {
      "service": {
        "name": "postgres",
        "description": "PostgreSQL - open source relational database",
        "url": "https://www.postgresql.org/docs/",
        "image": "docker.io/library/postgres:17-alpine",
        "command": null,
        "kind": "infrastructure",
        "architecture": [
          "amd64",
          "arm64"
        ]
      },
      "requirements": {
        "ram": {
          "min": 128,
          "recommended": 256
        }
      },
      "ports": [
        {
          "name": "tcp",
          "container_port": 5432,
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "name": "data",
          "mount_path": "/var/lib/postgresql/data",
          "host_path": null
        }
      ],
      "env": [
        {
          "name": "POSTGRES_USER",
          "value": "postgres",
          "kind": "prompted",
          "prompt": "Database admin username",
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_DB",
          "value": "postgres",
          "kind": "prompted",
          "prompt": "Default database name",
          "format": "string",
          "length": null
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "{{secret.postgres_password}}",
          "kind": "default",
          "prompt": null,
          "format": "string",
          "length": null
        }
      ],
      "requires": [],
      "nginx": null,
      "containers": [],
      "mappings": {
        "smtp": {},
        "auth": {}
      },
      "integrations": {
        "auth": [],
        "smtp": false
      },
      "tests": [
        {
          "name": "accepts-connections",
          "run": "for i in $(seq 1 15); do PGPASSWORD=$POSTGRES_PASSWORD psql -h 127.0.0.1 -p $RYRA_PORT_TCP -U $POSTGRES_USER -c 'SELECT 1' && exit 0; sleep 2; done; exit 1",
          "timeout": 60,
          "env": {}
        },
        {
          "name": "user-created",
          "run": "id postgres",
          "timeout": 30,
          "env": {}
        }
      ],
      "post_start": []
    },
