          "length": null
        }
      ],
      "requires": [],
      "nginx": {
        "upstream_port": "http"
      },
      "containers": [
        {
          "name": "postgres",
          "image": "docker.io/library/postgres:17-alpine",
          "command": null,
          "volumes": [
            {
              "name": "db-data",
