---
import Default from "@astrojs/starlight/components/SocialIcons.astro";
---

<button type="button" class="copy-docs" data-copy-docs aria-live="polite">
  <svg
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="9" y="9" width="11" height="11" rx="2" />
    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
  </svg>
  <span class="copy-docs-label">Copy docs to clipboard</span>
</button>

<Default {...Astro.props}><slot /></Default>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-copy-docs]");
  buttons.forEach((btn) => {
    const label = btn.querySelector<HTMLSpanElement>(".copy-docs-label");
    if (!label) return;
    btn.addEventListener("click", async () => {
      if (!navigator.clipboard) return;
      const original = label.textContent ?? "Copy docs to clipboard";
      try {
        const res = await fetch("/llms-full.txt");
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        label.textContent = "Copied";
      } catch {
        label.textContent = "Failed";
      }
      setTimeout(() => {
        label.textContent = original;
      }, 1600);
    });
  });
</script>

<style>
  .copy-docs {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    margin-inline-end: 4px;
    font: inherit;
    font-size: 0.8125rem;
    line-height: 1;
    color: var(--sl-color-text);
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    cursor: pointer;
    transition: color 120ms, border-color 120ms, background 120ms;
  }
  .copy-docs:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
  }
  .copy-docs svg { flex: 0 0 auto; }

  @media (max-width: 50rem) {
    .copy-docs { display: none; }
  }
</style>
