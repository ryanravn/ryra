---
// Layered Norwegian fjord mountain backdrop. Sits behind the hero.
---

<div class="mountains" aria-hidden="true">
  <svg viewBox="0 0 1600 700" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#f4ede2" />
        <stop offset="0.6" stop-color="#f4ede2" />
        <stop offset="1" stop-color="#ede2d0" />
      </linearGradient>
      <linearGradient id="m1" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#cdd9e0" stop-opacity="0.55" />
        <stop offset="1" stop-color="#cdd9e0" stop-opacity="0.15" />
      </linearGradient>
      <linearGradient id="m2" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#a3b6c2" stop-opacity="0.55" />
        <stop offset="1" stop-color="#a3b6c2" stop-opacity="0.18" />
      </linearGradient>
      <linearGradient id="m3" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#6b8497" stop-opacity="0.5" />
        <stop offset="1" stop-color="#6b8497" stop-opacity="0.12" />
      </linearGradient>
      <pattern id="dots" width="5" height="5" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.4" fill="#1d3e54" opacity="0.10" />
      </pattern>
    </defs>

    <rect width="1600" height="700" fill="url(#sky)" />

    <circle cx="1280" cy="170" r="80" fill="#f0c896" opacity="0.35" />
    <circle cx="1280" cy="170" r="55" fill="#e8b378" opacity="0.18" />

    <path
      d="M0,420 L120,360 L210,395 L320,330 L460,380 L580,310 L720,360 L860,300 L980,355 L1120,310 L1260,360 L1380,320 L1500,370 L1600,340 L1600,700 L0,700 Z"
      fill="url(#m1)"
    />
    <path
      d="M0,500 L80,450 L180,490 L280,420 L380,470 L480,410 L600,470 L720,410 L850,475 L990,420 L1120,470 L1260,420 L1400,475 L1520,440 L1600,470 L1600,700 L0,700 Z"
      fill="url(#m2)"
    />
    <path
      d="M0,580 L100,540 L200,575 L320,520 L440,570 L560,520 L700,580 L840,520 L980,570 L1120,520 L1260,575 L1400,530 L1520,565 L1600,540 L1600,700 L0,700 Z"
      fill="url(#m3)"
    />

    <path
      d="M310,335 L320,330 L335,345 M575,315 L580,310 L595,325 M855,305 L860,300 L880,322"
      stroke="#f4ede2"
      stroke-width="3"
      fill="none"
      opacity="0.55"
    />

    <rect width="1600" height="700" fill="url(#dots)" />

    <g transform="translate(1100,500)" opacity="0.85">
      <path d="M0,0 L8,-8 L16,0 Z" fill="#3a2e22" />
      <rect x="2" y="0" width="12" height="8" fill="#5a3a22" />
      <rect x="6" y="3" width="3" height="5" fill="#d97a3a" />
    </g>
  </svg>
</div>

<style>
  .mountains {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }
  .mountains svg {
    width: 100%;
    height: 100%;
  }
</style>
