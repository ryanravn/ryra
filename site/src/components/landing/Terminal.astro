---
interface Props {
  title?: string;
  label?: string;
}

const {
  title,
  label = "Terminal demonstration of the Ryra command-line tool",
} = Astro.props;

const hasChip = Astro.slots.has("chip");
---

<div class="terminal-wrap">
  <div class="terminal" role="img" aria-label={label}>
    <div class="terminal-bar">
      <span class="tdot r"></span>
      <span class="tdot y"></span>
      <span class="tdot g"></span>
      {title && <span class="terminal-title">{title}</span>}
    </div>
    <div class="terminal-body">
      <slot />
    </div>
  </div>
  {hasChip && (
    <div class="floating-chip" aria-hidden="true">
      <slot name="chip" />
    </div>
  )}
</div>

<script>
  // Each .terminal-wrap on the page animates its [data-step] children
  // independently, so multiple terminals can share the same chrome and
  // script without coordinating.
  const wraps = document.querySelectorAll<HTMLElement>(".terminal-wrap");
  wraps.forEach((wrap) => {
    const lines = wrap.querySelectorAll<HTMLElement>("[data-step]");
    if (lines.length === 0) return;
    const chip = wrap.querySelector<HTMLElement>(".floating-chip");

    const reset = () => {
      lines.forEach((el) => (el.style.display = "none"));
      chip?.classList.remove("revealed");
    };
    reset();

    const isCmd = (el: HTMLElement | undefined) =>
      !!el?.classList.contains("term-line") && !!el?.querySelector(".term-cmd");

    const delayFor = (el: HTMLElement, next: HTMLElement | undefined) => {
      if (isCmd(el)) return 700;
      if (el.querySelector(".term-table")) return 350;
      if (el.classList.contains("term-final")) return 0;
      // Pause longer before the next command so it reads like the user paused
      // to read the previous output before typing again.
      if (isCmd(next)) return 1400;
      return 220;
    };

    let i = 0;
    const tick = () => {
      if (i >= lines.length) {
        setTimeout(() => {
          reset();
          i = 0;
          tick();
        }, 6000);
        return;
      }
      const el = lines[i];
      el.style.display = el.classList.contains("term-line") ? "flex" : "block";
      if (el.dataset.revealChip !== undefined) {
        chip?.classList.add("revealed");
      }
      i++;
      setTimeout(tick, delayFor(el, lines[i]));
    };
    tick();
  });
</script>

<style>
  .terminal-wrap {
    position: relative;
    min-width: 0;
    width: 100%;
  }
  .terminal {
    position: relative;
    background: var(--fjord);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 30px 60px -20px rgba(14, 34, 48, 0.55),
      0 8px 20px -8px rgba(14, 34, 48, 0.4);
    border: 1px solid color-mix(in oklab, var(--fjord) 40%, var(--ink));
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: linear-gradient(180deg, #1a3a52 0%, #122c3e 100%);
    border-bottom: 1px solid #00000040;
  }
  .tdot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .tdot.r { background: #ff5f57; }
  .tdot.y { background: #febc2e; }
  .tdot.g { background: #28c840; }

  .terminal-title {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 11px;
    color: #8aa9bf;
    letter-spacing: 0.05em;
  }

  .terminal-body {
    padding: 22px 24px 26px;
    font-family: var(--mono);
    font-size: 13.5px;
    line-height: 1.62;
    color: #d6e4ee;
    /* Sized for the fully-revealed animation so the body never grows during
       the cycle. The hero uses align-items: center, so any height change
       here shifts the page. */
    min-height: 540px;
    /* Long lines (image refs, URLs) wrap rather than expanding the box. */
    overflow-x: hidden;
    overflow-wrap: anywhere;
  }
  .term-line {
    display: flex;
    gap: 10px;
  }
  .term-prompt {
    color: var(--cabin);
    user-select: none;
  }
  .term-cmd { color: var(--snow); }
  .term-out {
    color: #9fbacb;
    padding-left: 22px;
  }
  .term-ok { color: #7fb77a; }
  .term-arrow { color: var(--cabin); margin-right: 4px; }
  .term-blank { line-height: 0.4; }
  .term-comment {
    color: #5d7686;
    font-style: italic;
  }
  .term-step { color: #d6e4ee; }
  .term-step .term-arrow { color: var(--cabin); }
  .term-summary {
    color: #7fb77a;
    font-weight: 500;
  }

  .term-table {
    border-collapse: collapse;
    font-family: inherit;
    font-size: inherit;
    table-layout: auto;
    max-width: 100%;
  }
  .term-table th {
    text-align: left;
    padding: 2px 22px 6px 0;
    color: #e0b770;
    font-weight: 500;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .term-table td {
    padding: 2px 22px 2px 0;
    color: #9fbacb;
  }
  .term-table .term-name { color: #fff; }
  .term-table .term-up { color: #7fb77a; }
  .term-table th:first-child,
  .term-table td:first-child { padding-right: 32px; }
  .term-table th:nth-child(2),
  .term-table td:nth-child(2) { padding-right: 32px; }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: var(--cabin);
    vertical-align: middle;
    animation: blink 1.1s step-end infinite;
    margin-left: 2px;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .floating-chip {
    position: absolute;
    right: -28px;
    bottom: -32px;
    background: var(--paper);
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 12px;
    padding: 14px 18px 16px;
    /* Static dimensions: the chip never resizes during the animation, so the
       page never shifts when it appears. */
    width: 286px;
    height: 220px;
    box-sizing: border-box;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-2);
    box-shadow: 0 14px 30px -14px rgba(14, 34, 48, 0.35);
    opacity: 0;
    transform: rotate(0deg) translateY(20px) scale(0.96);
    transition:
      opacity 420ms ease-out,
      transform 520ms cubic-bezier(0.2, 0.7, 0.2, 1);
    will-change: opacity, transform;
  }
  .floating-chip.revealed {
    opacity: 1;
    transform: rotate(1.5deg) translateY(0) scale(1);
  }

  @media (max-width: 720px) {
    .floating-chip { display: none; }
  }
  @media (max-width: 600px) {
    /* Long image refs / URLs wrap on narrow viewports, taking up extra
       vertical space. Bump the static min-height so the body still doesn't
       grow during the animation cycle. */
    .terminal-body { min-height: 668px; }
  }
</style>
