---
// Animated terminal that types out a ryra session. Animation is driven by
// a small vanilla script that walks through pre-rendered lines, hidden
// until their turn.
---

<div class="terminal-wrap">
  <div class="terminal" role="img" aria-label="Terminal demonstration of the Ryra command-line tool">
    <div class="terminal-bar">
      <span class="tdot r"></span>
      <span class="tdot y"></span>
      <span class="tdot g"></span>
    </div>
    <div class="terminal-body" id="ryra-term">
      <div class="term-line" data-step><span class="term-prompt">$</span><span class="term-cmd">ryra add immich</span></div>
      <div class="term-out" data-step><span class="term-arrow">→</span> pulls ghcr.io/immich-app/immich-server:v2.7.4</div>
      <div class="term-out" data-step><span class="term-arrow">→</span> pulls ghcr.io/immich-app/postgres:14-vectorchord0.4.3</div>
      <div class="term-out" data-step><span class="term-arrow">→</span> pulls docker.io/valkey/valkey:9</div>
      <div class="term-out" data-step><span class="term-arrow">→</span> writes ~/.local/share/services/immich/immich.container</div>
      <div class="term-out" data-step><span class="term-arrow">→</span> starts immich on http://127.0.0.1:2283</div>
      <div class="term-out term-blank" data-step>&nbsp;</div>
      <div class="term-out term-ok" data-step data-reveal-chip>immich is running.</div>
      <div class="term-out" data-step>  URL: http://127.0.0.1:2283</div>
      <div class="term-line" data-step><span class="term-prompt">$</span><span class="term-cmd">ryra list</span></div>
      <div class="term-out" data-step style="padding-left: 0;">
        <table class="term-table">
          <thead>
            <tr><th>SERVICE</th><th>STATUS</th><th>URL</th></tr>
          </thead>
          <tbody>
            <tr><td class="term-name">caddy</td><td class="term-up">running</td><td>http://127.0.0.1:8080</td></tr>
            <tr><td class="term-name">forgejo</td><td class="term-up">running</td><td>http://127.0.0.1:3000</td></tr>
            <tr><td class="term-name">immich</td><td class="term-up">running</td><td>http://127.0.0.1:2283</td></tr>
            <tr><td class="term-name">vaultwarden</td><td class="term-up">running</td><td>http://127.0.0.1:8222</td></tr>
          </tbody>
        </table>
      </div>
      <div class="term-out term-comment" data-step># everything you run, you own.</div>
      <div class="term-line term-final" data-step><span class="term-prompt">$</span><span class="cursor"></span></div>
    </div>
  </div>
  <div class="floating-chip" id="floating-chip" aria-hidden="true">
    <div class="floating-chip-head">
      <span class="floating-chip-dot"></span>
      immich.container
    </div>
    <div class="floating-chip-path">~/.local/share/services/immich/</div>
    <div class="floating-chip-body">
      <span class="chip-section">[Container]</span><br />
      Image=ghcr.io/<br />immich-app/immich-server<br />
      PublishPort=2283:3001<br />
      Volume=%h/.local/share/<br />services/immich/data:/data<br />
      Network=immich.network
    </div>
  </div>
</div>

<script>
  const lines = document.querySelectorAll<HTMLElement>("#ryra-term [data-step]");
  const chip = document.getElementById("floating-chip");
  if (lines.length > 0) {
    const reset = () => {
      lines.forEach((el) => (el.style.display = "none"));
      chip?.classList.remove("revealed");
    };
    reset();

    const delayFor = (el: HTMLElement) => {
      if (el.classList.contains("term-line") && el.querySelector(".term-cmd")) return 700;
      if (el.querySelector(".term-table")) return 350;
      if (el.classList.contains("term-final")) return 0;
      return 220;
    };

    let i = 0;
    const tick = () => {
      if (i >= lines.length) {
        setTimeout(() => {
          reset();
          i = 0;
          tick();
        }, 6000);
        return;
      }
      const el = lines[i];
      el.style.display = el.classList.contains("term-line") ? "flex" : "block";
      if (el.dataset.revealChip !== undefined) {
        chip?.classList.add("revealed");
      }
      i++;
      setTimeout(tick, delayFor(el));
    };
    tick();
  }
</script>

<style>
  .terminal-wrap {
    position: relative;
    min-width: 0;
    width: 100%;
  }
  .terminal {
    position: relative;
    background: var(--fjord);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 30px 60px -20px rgba(14, 34, 48, 0.55),
      0 8px 20px -8px rgba(14, 34, 48, 0.4);
    border: 1px solid color-mix(in oklab, var(--fjord) 40%, var(--ink));
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: linear-gradient(180deg, #1a3a52 0%, #122c3e 100%);
    border-bottom: 1px solid #00000040;
  }
  .tdot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .tdot.r { background: #ff5f57; }
  .tdot.y { background: #febc2e; }
  .tdot.g { background: #28c840; }

  .terminal-body {
    padding: 22px 24px 26px;
    font-family: var(--mono);
    font-size: 13.5px;
    line-height: 1.62;
    color: #d6e4ee;
    /* Sized for the fully-revealed animation so the body never grows during
       the cycle. The hero uses align-items: center, so any height change
       here shifts the page. */
    min-height: 540px;
    /* Long lines (image refs, URLs) wrap rather than expanding the box. */
    overflow-x: hidden;
    overflow-wrap: anywhere;
  }
  .term-line {
    display: flex;
    gap: 10px;
  }
  .term-prompt {
    color: var(--cabin);
    user-select: none;
  }
  .term-cmd { color: var(--snow); }
  .term-out {
    color: #9fbacb;
    padding-left: 22px;
  }
  .term-ok { color: #7fb77a; }
  .term-arrow { color: var(--cabin); margin-right: 4px; }
  .term-blank { line-height: 0.4; }
  .term-comment {
    color: #5d7686;
    font-style: italic;
  }

  .term-table {
    border-collapse: collapse;
    font-family: inherit;
    font-size: inherit;
    table-layout: auto;
    max-width: 100%;
  }
  .term-table th {
    text-align: left;
    padding: 2px 22px 6px 0;
    color: #e0b770;
    font-weight: 500;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .term-table td {
    padding: 2px 22px 2px 0;
    color: #9fbacb;
  }
  .term-table .term-name { color: #fff; }
  .term-table .term-up { color: #7fb77a; }
  .term-table th:first-child,
  .term-table td:first-child { padding-right: 32px; }
  .term-table th:nth-child(2),
  .term-table td:nth-child(2) { padding-right: 32px; }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: var(--cabin);
    vertical-align: middle;
    animation: blink 1.1s step-end infinite;
    margin-left: 2px;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .floating-chip {
    position: absolute;
    right: -28px;
    bottom: -32px;
    background: var(--paper);
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 12px;
    padding: 14px 18px 16px;
    /* Static dimensions: the chip never resizes during the animation, so the
       page never shifts when it appears. */
    width: 286px;
    height: 220px;
    box-sizing: border-box;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-2);
    box-shadow: 0 14px 30px -14px rgba(14, 34, 48, 0.35);
    opacity: 0;
    transform: rotate(0deg) translateY(20px) scale(0.96);
    transition:
      opacity 420ms ease-out,
      transform 520ms cubic-bezier(0.2, 0.7, 0.2, 1);
    will-change: opacity, transform;
  }
  .floating-chip.revealed {
    opacity: 1;
    transform: rotate(1.5deg) translateY(0) scale(1);
  }
  .floating-chip-path {
    font-family: var(--mono);
    font-size: 10.5px;
    color: color-mix(in oklab, var(--ink-2) 65%, transparent);
    margin: -2px 0 10px;
    padding-bottom: 8px;
    border-bottom: 1px dashed color-mix(in oklab, var(--ink) 14%, transparent);
    word-break: break-all;
  }
  .floating-chip-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-family: var(--sans);
    font-size: 11px;
    color: var(--ember);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .floating-chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
  }
  .floating-chip-body {
    line-height: 1.55;
  }
  .chip-section { color: #a35a2a; }

  @media (max-width: 720px) {
    .floating-chip { display: none; }
  }
</style>
