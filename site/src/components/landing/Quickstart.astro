---
// Clickable steps that swap the code panel. Vanilla JS: toggle .active and
// the visible code block.

interface Step {
  title: string;
  desc: string;
  file: string;
  code: string; // already-marked-up HTML; safe because it's authored here
}

const steps: Step[] = [
  {
    title: "Install",
    desc: "One curl, one binary.",
    file: "install.sh",
    code: `<span class="k3"># Linux · Debian / Ubuntu / Fedora / Arch</span>
<span class="k4">$</span><span class="k5"> curl -fsSL </span><span class="k2">https://raw.githubusercontent.com/ryanravn/ryra/main/install.sh</span><span class="k5"> | sh</span>

<span class="k3"># verify</span>
<span class="k4">$</span><span class="k5"> ryra </span><span class="k1">--version</span>
<span class="k5">ryra 0.1.0</span>

<span class="k3"># browse the registry</span>
<span class="k4">$</span><span class="k5"> ryra search</span>
<span class="k5">SERVICE       SUPPORTS      DESCRIPTION</span>
<span class="k5">────────────────────────────────────────────────</span>
<span class="k5">forgejo       oidc, smtp    Self-hosted Git forge</span>
<span class="k5">immich        oidc          Photo & video management</span>
<span class="k5">nextcloud     oidc, smtp    Files & collaboration</span>
<span class="k5">vaultwarden   smtp          Bitwarden-compatible vault</span>
<span class="k5">…</span>`,
  },
  {
    title: "Add a service",
    desc: "Ryra prompts for the things that matter (SMTP, SSO) and writes the quadlet. No flags to memorise.",
    file: "ryra add forgejo",
    code: `<span class="k4">$</span><span class="k5"> ryra add forgejo</span>
<span class="k1">→</span><span class="k5"> pulls codeberg.org/forgejo/forgejo:11</span>
<span class="k1">→</span><span class="k5"> writes ~/.local/share/services/forgejo/forgejo.container</span>

<span class="k3">? SMTP for outgoing email?</span><span class="k5"> (y/N) › </span><span class="k1">y</span>
<span class="k3">?   Relay host ›</span><span class="k5"> smtp.fastmail.com</span>
<span class="k3">?   Username ›</span><span class="k5"> user@example.com</span>
<span class="k3">?   Password ›</span><span class="k5"> </span><span class="k2">********</span>

<span class="k3">? Sign-on via Authelia (OIDC)?</span><span class="k5"> (y/N) › </span><span class="k1">y</span>
<span class="k1">→</span><span class="k5"> registering OIDC client with authelia</span>
<span class="k1">→</span><span class="k5"> injecting credentials into forgejo .env</span>

<span class="k1">→</span><span class="k5"> starts forgejo on http://127.0.0.1:3000</span>

<span class="k5">forgejo is running.</span>
<span class="k5">  URL: http://127.0.0.1:3000</span>
<span class="k5">  Sign in with the SSO button or admin/$INITIAL_PASSWORD.</span>`,
  },
  {
    title: "It's just systemd + podman now",
    desc: "Ryra is a generator, not a runtime. Once your service is up, the box looks like a sysadmin set it up by hand.",
    file: "after ryra",
    code: `<span class="k3"># ryra has done its job. Everything that's running</span>
<span class="k3"># is plain systemd + rootless podman.</span>

<span class="k4">$</span><span class="k5"> systemctl --user status forgejo.service</span>
<span class="k1">●</span><span class="k5"> forgejo.service - Forgejo</span>
<span class="k5">     Active: </span><span class="k1">active (running)</span><span class="k5"> since Tue 14:22:18 CEST</span>

<span class="k4">$</span><span class="k5"> journalctl --user -fu forgejo.service</span>
<span class="k4">$</span><span class="k5"> podman logs systemd-forgejo</span>

<span class="k3"># everything lives in plain files</span>
<span class="k4">$</span><span class="k5"> ls ~/.local/share/services/forgejo/</span>
<span class="k5">forgejo.container  .env  metadata.toml  data/</span>

<span class="k3"># uninstall ryra. your services keep running.</span>
<span class="k4">$</span><span class="k5"> rm /usr/local/bin/ryra</span>
<span class="k4">$</span><span class="k5"> systemctl --user restart forgejo.service</span>
<span class="k1">●</span><span class="k5"> forgejo.service - </span><span class="k1">active (running)</span><span class="k5">   ← still works.</span>`,
  },
];
---

<div class="qs-scroll" style={`--qs-step-count: ${steps.length}`}>
  <div class="qs-stick">
    <div class="qs-grid">
      <div class="qs-steps" role="tablist">
        {steps.map((s, i) => (
          <button
            class:list={["qs-step", { active: i === 0 }]}
            data-step-index={i}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
          >
            <span class="num">0{i + 1}</span>
            <span>
              <span class="title">{s.title}</span>
              <span class="desc">{s.desc}</span>
            </span>
          </button>
        ))}
        <div class="qs-progress" aria-hidden="true">
          <div class="qs-progress-bar" id="qs-progress-bar"></div>
        </div>
        <a href="/intro/" class="qs-docs-link">
          Read the docs
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
      <div class="qs-code">
        <div class="qs-code-bar">
          <span class="qs-tdot r"></span>
          <span class="qs-tdot y"></span>
          <span class="qs-tdot g"></span>
          <span class="file" id="qs-file">{steps[0].file}</span>
          <span class="qs-counter" id="qs-counter">step 1 / {steps.length}</span>
        </div>
        {steps.map((s, i) => (
          <pre
            class:list={["qs-code-body", { hidden: i !== 0 }]}
            data-step-body={i}
            set:html={s.code}
          />
        ))}
      </div>
    </div>
  </div>
  {/* Step anchors: stacked one-viewport-tall blocks. The IntersectionObserver
      fires when each anchor crosses the viewport center, advancing the active
      step. This is the standard scrollytelling pattern — no scroll math, no
      rAF, no fragile event chains. */}
  {steps.map((_, i) => (
    <div class="qs-anchor" data-step-anchor={i} aria-hidden="true"></div>
  ))}
</div>

<script define:vars={{ files: steps.map((s) => s.file), total: steps.length }}>
  // Diagnostic: lets us confirm in DevTools that the new build is loaded.
  console.log("[ryra/quickstart] init", { steps: total });

  const buttons = document.querySelectorAll(".qs-step");
  const bodies = document.querySelectorAll("[data-step-body]");
  const anchors = document.querySelectorAll("[data-step-anchor]");
  const fileEl = document.getElementById("qs-file");
  const counterEl = document.getElementById("qs-counter");
  const progressBar = document.getElementById("qs-progress-bar");
  const scrollEl = document.querySelector(".qs-scroll");
  const stick = document.querySelector(".qs-stick");

  // Reduced-motion only suppresses the line-by-line typewriter reveal and
  // smooth click-scroll. The pinned panel and step bucketing are *layout*,
  // not motion, so they stay on regardless of the preference.
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Pinning is enabled on every screen size. On narrow layouts the steps
  // and code panel stack, so the sticky element is tall — CSS caps the code
  // panel height in those cases so the full stick fits in the viewport.

  // Wrap each code line in a span so we can fade them in one at a time.
  bodies.forEach((body) => {
    const lines = body.innerHTML.split("\n");
    body.innerHTML = lines
      .map((line) => `<span class="qs-line">${line}</span>`)
      .join("\n");
    body.dataset.animReady = "true";
  });

  let activeTimers = [];
  let currentIdx = 0;

  const stopAnimation = () => {
    activeTimers.forEach(clearTimeout);
    activeTimers = [];
  };
  const showAllLines = (body) => {
    body.querySelectorAll(".qs-line").forEach((l) => l.classList.add("qs-line-shown"));
  };
  const delayFor = (lineEl) => {
    const text = (lineEl.textContent || "").trimStart();
    if (text.startsWith("$")) return 280;
    return 70;
  };
  const animateStep = (idx) => {
    stopAnimation();
    const body = bodies[idx];
    if (!body) return;
    const lines = body.querySelectorAll(".qs-line");
    if (reducedMotion) {
      lines.forEach((l) => l.classList.add("qs-line-shown"));
      return;
    }
    lines.forEach((l) => l.classList.remove("qs-line-shown"));
    let delay = 0;
    lines.forEach((line) => {
      const t = setTimeout(() => line.classList.add("qs-line-shown"), delay);
      activeTimers.push(t);
      delay += delayFor(line);
    });
  };

  const setActive = (idx) => {
    if (idx === currentIdx) return;
    currentIdx = idx;
    buttons.forEach((b) => {
      const on = Number(b.dataset.stepIndex) === idx;
      b.classList.toggle("active", on);
      b.setAttribute("aria-selected", on ? "true" : "false");
    });
    bodies.forEach((body) => {
      body.classList.toggle("hidden", Number(body.dataset.stepBody) !== idx);
    });
    if (fileEl) fileEl.textContent = files[idx];
    if (counterEl) counterEl.textContent = `step ${idx + 1} / ${total}`;
    animateStep(idx);
  };

  // ─── Step changes via IntersectionObserver ───────────────────────────
  // Each anchor is one viewport tall (CSS). We use rootMargin to collapse
  // the observation root to a thin band at viewport center; whichever
  // anchor crosses that band is the active step. No scroll math, no rAF.
  if (anchors.length && "IntersectionObserver" in window) {
    bodies.forEach((body) => {
      if (Number(body.dataset.stepBody) !== 0) showAllLines(body);
    });
    // Kick off step 0's reveal so the panel isn't empty on first paint.
    // setActive(0) would bail on `idx === currentIdx`, so call animate
    // directly. With reducedMotion, animateStep instantly shows all lines.
    animateStep(0);

    const observer = new IntersectionObserver(
      (entries) => {
        // Pick the most-visible anchor among those currently intersecting.
        let best = null;
        entries.forEach((e) => {
          if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) {
            best = e;
          }
        });
        if (best) {
          const idx = Number(best.target.dataset.stepAnchor);
          setActive(idx);
        }
      },
      // A 4px-tall band at viewport center. 48% top + 48% bottom = 4% (~30px)
      // band, generous enough for IO to fire reliably while still ensuring
      // exactly one anchor occupies it at a time.
      { rootMargin: "-48% 0px -48% 0px", threshold: [0, 0.5, 1] }
    );
    anchors.forEach((a) => observer.observe(a));

    // Progress rail: still scroll-driven, but with a single observer + rAF.
    if (progressBar && scrollEl) {
      let rafQueued = false;
      const updateBar = () => {
        if (rafQueued) return;
        rafQueued = true;
        requestAnimationFrame(() => {
          rafQueued = false;
          const rect = scrollEl.getBoundingClientRect();
          const scrollable = scrollEl.offsetHeight - window.innerHeight;
          if (scrollable <= 0) return;
          const scrolled = Math.max(0, Math.min(scrollable, -rect.top));
          progressBar.style.transform = `scaleY(${scrolled / scrollable})`;
        });
      };
      window.addEventListener("scroll", updateBar, { passive: true });
      window.addEventListener("resize", updateBar, { passive: true });
      updateBar();
    }
  } else {
    // Narrow / no IntersectionObserver: pre-fill all panels and rely on
    // click-driven step changes.
    bodies.forEach(showAllLines);
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = Number(btn.dataset.stepIndex);
      const anchor = anchors[idx];
      if (anchor) {
        // Scroll the page so the matching anchor lands in the center band.
        const rect = anchor.getBoundingClientRect();
        const target = rect.top + window.scrollY - window.innerHeight * 0.5 + rect.height * 0.5;
        window.scrollTo({ top: target, behavior: reducedMotion ? "auto" : "smooth" });
      } else {
        setActive(idx);
      }
    });
  });
</script>

<style>
  /* ─── Scroll-pin wrapper ───────────────────────────────────────────
     The wrapper's total height = sticky panel's natural height + N
     anchors, each one viewport tall. While the anchors scroll past
     behind the sticky panel, IntersectionObserver advances the step. */
  .qs-scroll {
    position: relative;
  }
  .qs-stick {
    position: sticky;
    /* Pin flush below the topbar (~52px) and fill the rest of the viewport.
       Inside, the panel is flex-centered so the dark section background
       breathes symmetrically above and below — much nicer than the panel
       hugging the top with all the empty space pooled at the bottom. */
    top: 52px;
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    /* Sit on top of the anchors so they don't visually extend the panel. */
    z-index: 1;
  }
  /* The grid was using its own align-items inside the old stick; reset so
     the flex parent governs vertical placement. */
  .qs-stick > .qs-grid {
    width: 100%;
  }
  /* Step anchors: stacked, one viewport per step. They take up real height
     to give the sticky panel something to scroll past, but they're empty
     and visually invisible. Step 0 is the default `currentIdx`, so until
     anchor 1 reaches the center band, the first step stays active. */
  .qs-anchor {
    height: 90vh;
    pointer-events: none;
  }
  .qs-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 50px;
    align-items: start;
  }
  @media (max-width: 980px) {
    .qs-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
  .qs-steps {
    display: grid;
    gap: 6px;
    position: relative;
  }
  /* Vertical scroll rail along the left of the steps column. The bar
     scales from 0..1 as the user scrolls through the section. */
  .qs-progress {
    position: absolute;
    left: -10px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }
  .qs-progress-bar {
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, var(--cabin) 0%, var(--ember) 100%);
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 120ms linear;
  }
  @media (max-width: 980px) {
    .qs-progress { display: none; }
  }
  .qs-step {
    padding: 18px 20px;
    border-radius: 10px;
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
    color: #c5b9a6;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 14px;
    align-items: start;
    text-align: left;
    font-family: var(--sans);
    font-size: 15px;
    width: 100%;
  }
  .qs-step:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .qs-step.active {
    background: rgba(217, 122, 58, 0.1);
    border-color: color-mix(in oklab, var(--cabin) 35%, transparent);
    color: var(--snow);
  }
  .qs-step .num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--cabin);
    padding-top: 3px;
  }
  .qs-step .title {
    font-family: var(--serif);
    font-size: 19px;
    font-weight: 500;
    color: var(--snow);
    display: block;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .qs-step .desc {
    font-size: 13.5px;
    line-height: 1.5;
    color: #9d8f7c;
    display: block;
  }
  .qs-step.active .desc {
    color: #c5b9a6;
  }
  .qs-docs-link {
    margin-top: 18px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: 10px;
    border: 1px solid color-mix(in oklab, var(--cabin) 45%, transparent);
    background: rgba(217, 122, 58, 0.08);
    color: var(--snow);
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    width: fit-content;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .qs-docs-link:hover {
    background: rgba(217, 122, 58, 0.16);
    border-color: var(--cabin);
  }
  .qs-docs-link svg {
    transition: transform 0.15s ease;
  }
  .qs-docs-link:hover svg {
    transform: translateX(2px);
  }

  .qs-code {
    background: #0a1620;
    border-radius: 12px;
    border: 1px solid #ffffff10;
    overflow: hidden;
    /* Fixed height tall enough for the longest step's content (step 3,
       18 lines) so the panel doesn't jump between steps. Wrapping
       handles long URLs without horizontal scroll. */
    height: 480px;
    display: flex;
    flex-direction: column;
  }
  .qs-code-bar { flex: 0 0 auto; }
  .qs-code-bar {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    background: #08111a;
    border-bottom: 1px solid #ffffff08;
    font-family: var(--mono);
    font-size: 12px;
    color: #6f8a9d;
    gap: 10px;
  }
  .qs-tdot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
  }
  .qs-tdot.r { background: #ff5f57; }
  .qs-tdot.y { background: #febc2e; }
  .qs-tdot.g { background: #28c840; }
  .qs-code-bar .file {
    color: #aac3d4;
    margin-left: 8px;
  }
  .qs-counter {
    margin-left: auto;
    color: #6f8a9d;
  }
  .qs-code-body {
    padding: 22px 24px;
    margin: 0;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.65;
    color: #d6e4ee;
    /* `pre-wrap` + `anywhere` lets long URLs wrap mid-string instead
       of forcing a horizontal scrollbar. `overflow: hidden` clips any
       residual overflow rather than adding a scrollbar. */
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    overflow: hidden;
    flex: 1 1 auto;
    min-height: 0;
  }
  .qs-code-body.hidden { display: none; }

  /* Line-by-line reveal. The script wraps each line in `.qs-line` and sets
     `data-anim-ready` on the body, so without JS the lines render as plain
     inline text and stay visible. With JS, the active panel starts at
     opacity 0 until `qs-line-shown` is added on a timer. */
  .qs-code-body[data-anim-ready] :global(.qs-line) {
    display: inline-block;
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 220ms ease-out, transform 220ms ease-out;
  }
  .qs-code-body[data-anim-ready] :global(.qs-line.qs-line-shown) {
    opacity: 1;
    transform: translateY(0);
  }

  .qs-code-body :global(.k1) { color: #e0b770; }
  .qs-code-body :global(.k2) { color: #d97a3a; }
  .qs-code-body :global(.k3) { color: #7fb77a; }
  .qs-code-body :global(.k4) { color: #8fb4d8; }
  .qs-code-body :global(.k5) { color: #c5d4e0; }

  /* ─── Mobile overrides ─────────────────────────────────────────────
     Placed at the end of the stylesheet so they win on source order.
     Astro's `:where()` scoping keeps specificity equal to the desktop
     rules above; without later source order they'd lose the cascade. */
  @media (max-width: 980px) {
    .qs-stick {
      top: 64px;
      min-height: 0;
      display: block;
      padding-top: 16px;
      padding-bottom: 24px;
    }
    .qs-anchor { height: 100vh; }
    .qs-grid { gap: 14px; }
    .qs-steps { gap: 4px; }
    .qs-step { padding: 10px 14px; }
    .qs-step .title { font-size: 16px; margin-bottom: 2px; }
    .qs-step .desc { display: none; }
    .qs-progress { display: none; }
    /* Narrower viewport wraps more lines, so the code panel needs more
       height. 580px fits step 1's wrapped install.sh without clipping. */
    .qs-code { height: 580px; }
    .qs-code-body { font-size: 11.5px; line-height: 1.55; padding: 16px 18px; }
  }
</style>
