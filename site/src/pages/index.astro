---
import Mountains from "../components/landing/Mountains.astro";
import Terminal from "../components/landing/Terminal.astro";
import Quickstart from "../components/landing/Quickstart.astro";
import MountainDivider from "../components/landing/MountainDivider.astro";

const installCmd = "curl -fsSL https://raw.githubusercontent.com/ryanravn/ryra/main/install.sh | sh";

const features = [
  {
    icon: "lock",
    tag: "01",
    title: "Rootless. systemd-native.",
    body: "Containers run rootless under your user via podman, and each service is a plain systemd unit. systemctl --user and journalctl --user work the way you'd expect.",
  },
  {
    icon: "spark",
    tag: "02",
    title: "Tailnet by default.",
    body: "Built-in Tailscale support: any service can sit on your private tailnet with HTTPS, reachable from any of your devices without exposing it to the public internet. Or keep it on localhost. Or front it with Caddy. Pick per service.",
  },
  {
    icon: "key",
    tag: "03",
    title: "One login, optional.",
    body: "Add Authelia once and any service that speaks OIDC wires up to it. One sign-in across the stack. Particularly handy when you're running multiple AI agents and want a real security boundary between them.",
  },
  {
    icon: "compass",
    tag: "04",
    title: "E2E tested in VMs.",
    body: "Every service is verified end-to-end in an ephemeral QEMU VM by a custom Rust test framework. Browser flows, OIDC login, SMTP delivery: all asserted before a service lands in the registry.",
  },
  {
    icon: "layers",
    tag: "05",
    title: "Startup stack, bundled.",
    body: "The bundled registry covers most of what a small team needs: file storage, Supabase, a CRM, tasks, password vault, helpdesk, monitoring, AI chat. Need something else? Custom registries are a one-liner.",
  },
  {
    icon: "branch",
    tag: "06",
    title: "Clean state, easy reset.",
    body: "All service state lives under ~/.local/share/services/, plus one global preferences file. ryra reset wipes everything. ryra upgrade swaps images without drift. Move to a new box with one tar.",
  },
];

const principles = [
  {
    n: "/01",
    title: "Least privilege",
    body: "Containers run rootless under your user via podman. No Docker daemon, no privileged sockets, no permanent sudo. Elevated permissions only when there's no alternative, never sticky.",
  },
  {
    n: "/02",
    title: "Leaves no trace",
    body: "Ryra is a scaffolding tool, not a runtime. It writes plain systemd units and exits; systemd owns the lifecycle, the data lives in plain folders, the configs are text. Uninstall ryra and your stack keeps running.",
  },
  {
    n: "/03",
    title: "Tested, every service",
    body: "Every registry service has an end-to-end test that boots a fresh QEMU VM and asserts the full lifecycle: install, HTTP, OIDC, SMTP, removal. The same loop runs in CI and on your laptop.",
  },
  {
    n: "/04",
    title: "For agents, sysadmins, and beginners",
    body: "One command stands up a service end-to-end. An AI agent can drive ryra unsupervised inside a sandbox VM. A highly skilled sysadmin can read and audit every quadlet it writes. A first-timer gets a working stack without learning systemd or podman first.",
  },
];

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ryra: self-host with one command per service</title>
    <meta
      name="description"
      content="Ryra is a CLI for self-hosting on a single Linux box. One command per service: pulls the image, writes a systemd quadlet, runs under rootless podman."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="topbar">
      <div class="topbar-inner">
        <a href="/" class="brand">
          <svg class="mark" width="26" height="26" viewBox="0 0 32 32" fill="none">
            <defs>
              <linearGradient id="ryra-grad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#d97a3a" />
                <stop offset="1" stop-color="#c25a2c" />
              </linearGradient>
            </defs>
            <path d="M2,26 L12,4 L30,26 Z" fill="url(#ryra-grad)" />
            <path d="M17,26 L17,21 L20,18 L23,21 L23,26 Z" fill="#0e2230" />
          </svg>
          Ryra
        </a>
        <nav class="nav">
          <a href="#features">Features</a>
          <a href="#examples">Examples</a>
          <a href="#quickstart">Quickstart</a>
          <a href="#testing">Testing</a>
          <a href="#philosophy">Philosophy</a>
        </nav>
        <div class="topbar-right">
          <a href="/intro/" class="docs-link">Docs</a>
          <span class="pill"><span class="dot"></span>v0.1.0 · pre-release</span>
          <a class="gh-btn" href="https://github.com/ryanravn/ryra" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 2a10 10 0 00-3.2 19.5c.5.1.7-.2.7-.5v-2c-2.8.6-3.4-1.2-3.4-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.4 1.1 3 .8.1-.7.4-1.2.7-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10 10 0 0012 2z"
              />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <main>
      <section class="hero">
        <Mountains />
        <div class="hero-inner">
          <div>
            <h1 class="headline">
              Self-host your life or business with <em>Ryra</em>.
            </h1>
            <p class="lede">
              Ryra is a command-line tool for running your own apps on a single Linux machine. Type <code>ryra add <em>&lt;service&gt;</em></code>
              and it installs itself in containers using Podman. Sign in to everything with one account (SSO) if you choose. Keep it
              private, share it across your own global private network, or expose it to the internet.
            </p>
            <div class="cta-row">
              <button class="install" id="copy-install" type="button">
                <span class="prompt">$</span>
                <span class="install-cmd">{installCmd}</span>
                <span class="copy">COPY</span>
              </button>
              <a href="#features" class="cta cta-secondary">
                See how it works
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </div>
            <div class="meta-row">
              <div class="item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7.5"/></svg>
                Podman
              </div>
              <div class="item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7.5"/></svg>
                End-to-end tested
              </div>
              <div class="item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7.5"/></svg>
                Free and open source forever
              </div>
            </div>
          </div>
          <Terminal />
        </div>
      </section>

      <section class="bleed" id="features">
        <div class="container">
          <div class="section-head">
            <div>
              <h2 class="section-title">Features</h2>
            </div>
          </div>
          <div class="feat-grid">
            {features.map((f) => (
              <div class="feat">
                {f.icon === "compass" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5L13 13l-4.5 2.5L11 11z"/></svg>
                )}
                {f.icon === "lock" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 018 0v3"/></svg>
                )}
                {f.icon === "layers" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/><path d="M3 17l9 5 9-5" opacity="0.55"/></svg>
                )}
                {f.icon === "spark" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v4M12 17v4M3 12h4M17 12h4"/><path d="M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8" opacity="0.6"/></svg>
                )}
                {f.icon === "branch" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="9" r="2"/><path d="M6 8v8M6 14c4 0 6-1.5 6-5h4"/></svg>
                )}
                {f.icon === "heart" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20s-7-4.4-7-10a4 4 0 017-2.6A4 4 0 0119 10c0 5.6-7 10-7 10z"/></svg>
                )}
                {f.icon === "key" && (
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="12" r="4"/><path d="M12 12h9M16 12v3M21 12v4"/></svg>
                )}
                <h3>{f.title}</h3>
                <p>{f.body}</p>
                <span class="badge">{f.tag}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <MountainDivider variant="c" from="var(--snow)" fill="var(--paper)" height={92} />

      <section class="bleed examples" id="examples">
        <div class="container">
          <div class="section-head">
            <div>
              <h2 class="section-title">Examples</h2>
            </div>
          </div>

          <div class="examples-list">
            <article class="example">
              <div class="example-text">
                <span class="example-tag">/01</span>
                <h3>Replace one app at a time.</h3>
                <p>
                  Most of self-hosting is a single web app. Pick one, type one command, walk away with a new URL on
                  your Tailnet or your domain.
                </p>
                <pre class="example-cmd"><code><span class="p">$</span> ryra add vikunja</code></pre>
                <p class="example-foot">
                  Same shape for Forgejo, Paperless, Vaultwarden, Open WebUI, Uptime Kuma, and the rest of the registry.
                </p>
              </div>
              <div class="example-visual">
                <img
                  class="example-img"
                  src="/screenshots/vikunja.webp"
                  alt="Vikunja task manager: a dark UI with sidebar (Overview, Upcoming, Projects, Labels, Teams) and an empty task list captioned 'Nothing to do — Have a nice day!'"
                  loading="lazy"
                  decoding="async"
                  width="1996"
                  height="1086"
                />
              </div>
            </article>

            <article class="example reverse">
              <div class="example-text">
                <span class="example-tag">/02</span>
                <h3>One login across the stack.</h3>
                <p>
                  Install Authelia (or optionally point ryra at your own OIDC provider). Any service that speaks
                  OIDC hooks into it on <code>ryra add</code>. One login across the lot.
                </p>
                <pre class="example-cmd"><code><span class="p">$</span> ryra add seafile immich</code></pre>
              </div>
              <div class="example-visual">
                <svg class="auth-diagram" viewBox="0 0 360 240" role="img" aria-label="Authelia issues OIDC to Seafile and Immich" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="auth-node" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#d97a3a" />
                      <stop offset="1" stop-color="#c25a2c" />
                    </linearGradient>
                  </defs>
                  <path d="M 180 70 C 180 110, 90 120, 90 170" fill="none" stroke="#1d3e54" stroke-width="1.4" stroke-dasharray="4 4" opacity="0.55" />
                  <path d="M 180 70 C 180 110, 270 120, 270 170" fill="none" stroke="#1d3e54" stroke-width="1.4" stroke-dasharray="4 4" opacity="0.55" />
                  <text x="118" y="125" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b8497" text-anchor="middle">OIDC</text>
                  <text x="242" y="125" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b8497" text-anchor="middle">OIDC</text>
                  <g>
                    <rect x="120" y="24" width="120" height="48" rx="10" fill="url(#auth-node)" />
                    <text x="180" y="48" font-family="Fraunces, Georgia, serif" font-weight="500" font-size="16" fill="#f4ede2" text-anchor="middle">Authelia</text>
                    <text x="180" y="63" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#f4ede2" opacity="0.78" text-anchor="middle">OIDC issuer</text>
                  </g>
                  <g>
                    <rect x="30" y="170" width="120" height="48" rx="10" fill="#f4ede2" stroke="#1d3e54" stroke-width="1.2" />
                    <text x="90" y="194" font-family="Fraunces, Georgia, serif" font-weight="500" font-size="16" fill="#0e2230" text-anchor="middle">Seafile</text>
                    <text x="90" y="209" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#3a2e22" opacity="0.65" text-anchor="middle">files</text>
                  </g>
                  <g>
                    <rect x="210" y="170" width="120" height="48" rx="10" fill="#f4ede2" stroke="#1d3e54" stroke-width="1.2" />
                    <text x="270" y="194" font-family="Fraunces, Georgia, serif" font-weight="500" font-size="16" fill="#0e2230" text-anchor="middle">Immich</text>
                    <text x="270" y="209" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#3a2e22" opacity="0.65" text-anchor="middle">photos</text>
                  </g>
                </svg>
              </div>
            </article>

            <article class="example">
              <div class="example-text">
                <span class="example-tag">/03</span>
                <h3>Run anything.</h3>
                <p>
                  The registry is a folder of <code>service.toml</code> and quadlet files. Fork it, drop a definition
                  in for my_app (or whatever you need), point ryra at your registry, install with the same command.
                </p>
                <pre class="example-cmd"><code><span class="p">$</span> ryra registry add my_registry https://github.com/you/registry
<span class="p">$</span> ryra add my_registry/my_app</code></pre>
                <p class="example-foot">
                  No plugin API to learn. If you can write a systemd unit, you can extend ryra.
                </p>
              </div>
              <div class="example-visual">
                <img
                  class="example-img"
                  src="/screenshots/posthog.webp"
                  alt="PostHog dashboards view: a 'Default project' workspace with sidebar links for Dashboards, Activity, Data, Apps, Product analytics, SQL editor, Web analytics, and a single 'My App Dashboard' row in the table."
                  loading="lazy"
                  decoding="async"
                  width="3000"
                  height="1722"
                />
              </div>
            </article>
          </div>
        </div>
      </section>

      <MountainDivider variant="b" from="var(--paper)" fill="var(--ink)" height={92} />

      <section class="bleed quickstart" id="quickstart">
        <div class="container">
          <div class="section-head">
            <div>
              <h2 class="section-title">Quickstart</h2>
            </div>
          </div>
          <Quickstart />
        </div>
      </section>

      <MountainDivider variant="a" from="var(--ink)" fill="var(--snow)" height={92} />

      <section class="bleed sandbox" id="testing">
        <div class="container">
          <div class="sandbox-grid">
            <div>
              <h2 class="section-title">Test your stack with virtual machines</h2>
              <p class="section-sub" style="margin-top: 22px;">
                <code>ryra test</code> boots an ephemeral QEMU VM, installs whatever combination of
                services you want, and runs assertions end to end. Wire Authelia + Caddy + Immich
                + Nextcloud, prove SSO works across all four, throw the VM away. Your real machine
                never sees the experiment until you're sure.
              </p>
              <ul class="sandbox-points">
                <li>
                  <strong>A safe sandbox for AI agents.</strong> Let Claude or Codex iterate on
                  your stack: new services, quadlet tweaks, OIDC wiring, all inside a
                  throwaway VM. Agents can break things until they don't, without ever touching
                  your home server.
                </li>
                <li>
                  <strong>The same engine that gates the registry.</strong> Every service ships
                  only after it boots cleanly in this loop. The CI you run on your laptop is the
                  CI that protects the project.
                </li>
                <li>
                  <strong>Composable lifecycle tests.</strong> Chain services together (reverse
                  proxy, auth provider, app) and verify the full picture, not just one container.
                </li>
              </ul>
            </div>
            <div class="sandbox-term-wrap">
              <div class="sandbox-term">
                <div class="sandbox-term-bar">
                  <span class="tdot r"></span>
                  <span class="tdot y"></span>
                  <span class="tdot g"></span>
                  <span class="sandbox-term-title">vm: fedora-43 · kvm</span>
                </div>
                <pre class="sandbox-term-body"><code><span class="t-prompt">$</span> <span class="t-cmd">ryra test immich-oidc --keep-alive</span>
<span class="t-out">booting fedora-43 (qemu, kvm) ............ <span class="t-ok">ok</span></span>
<span class="t-out">ssh ready on 127.0.0.1:2222</span>
<span class="t-step">▸ ryra add caddy</span>
<span class="t-step">▸ ryra add authelia --url https://auth.test.local</span>
<span class="t-step">▸ ryra add immich --auth --url https://immich.test.local</span>
<span class="t-out">probe https://immich.test.local .......... <span class="t-ok">200</span></span>
<span class="t-out">browser oidc login flow .................. <span class="t-ok">ok</span></span>
<span class="t-out">smtp delivery to inbucket ................ <span class="t-ok">ok</span></span>
<span class="t-blank">&nbsp;</span>
<span class="t-summary">✓ all assertions passed in 2m41s</span>
<span class="t-comment"># vm kept alive: ssh -p 2222 ryra@127.0.0.1</span></code></pre>
              </div>
            </div>
          </div>
        </div>
      </section>

      <MountainDivider variant="c" from="var(--snow)" fill="var(--paper)" height={92} />

      <section class="bleed why" id="philosophy">
        <div class="container">
          <div class="why-grid">
            <div>
              <h2 class="section-title">Philosophy</h2>
              <p class="section-sub" style="margin-top: 22px;">
                Most of the time, all you need is one single machine to run a website, sync your files, or
                keep your photos. A few hours, and the right tools. Ryra is the right tools: opinionated
                where it has to be, out of the way everywhere else.
              </p>
            </div>
            <div class="principles">
              {principles.map((p) => (
                <div class="principle">
                  <span class="num">{p.n}</span>
                  <div>
                    <h4>{p.title}</h4>
                    <p>{p.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div style="display: flex; justify-content: center; margin-top: 56px;">
            <a href="/intro/" class="cta cta-secondary">
              Read the docs
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </div>
        </div>
      </section>

      <MountainDivider variant="a" from="var(--paper)" fill="var(--fjord)" height={86} />
    </main>

    <footer>
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="brand brand-light">
            <svg class="mark" width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <defs>
                <linearGradient id="ryra-grad-footer" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0" stop-color="#d97a3a" />
                  <stop offset="1" stop-color="#c25a2c" />
                </linearGradient>
              </defs>
              <path d="M2,26 L12,4 L30,26 Z" fill="url(#ryra-grad-footer)" />
              <path d="M17,26 L17,21 L20,18 L23,21 L23,26 Z" fill="#f4ede2" />
            </svg>
            Ryra
          </div>
          <p>A CLI for self-hosting on a single Linux box. Free and open source forever, AGPL-3.0.</p>
        </div>
        <div>
          <h5>Tool</h5>
          <ul>
            <li><a href="/getting-started/installation/">Install</a></li>
            <li><a href="/services/">Services</a></li>
            <li><a href="https://github.com/ryanravn/ryra/releases">Releases</a></li>
            <li><a href="https://github.com/ryanravn/ryra">Source</a></li>
          </ul>
        </div>
        <div>
          <h5>Learn</h5>
          <ul>
            <li><a href="/intro/">Docs</a></li>
            <li><a href="/getting-started/quick-start/">Quick start</a></li>
            <li><a href="/guides/configuration/">Configuration</a></li>
            <li><a href="/guides/exposure-modes/">Exposure modes</a></li>
          </ul>
        </div>
        <div>
          <h5>Community</h5>
          <ul>
            <li><a href="https://github.com/ryanravn/ryra">GitHub</a></li>
            <li><a href="https://github.com/ryanravn/ryra/issues">Issues</a></li>
            <li><a href="https://github.com/ryanravn/ryra/discussions">Discussions</a></li>
            <li><a href="https://github.com/ryanravn/ryra/blob/main/CONTRIBUTING.md">Contribute</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-meta">
        <span>
          © 2026 · Erlend Ravn Ryan
          <svg class="flag-no" viewBox="0 0 22 16" width="18" height="13" role="img" aria-label="Norway">
