[Unit]
Description=Twenty Redis cache
StartLimitIntervalSec=60
StartLimitBurst=3

[Container]
Image=docker.io/library/redis:7-alpine
AutoUpdate=registry
ContainerName=twenty-redis
Network=twenty.network:alias=redis
Exec=redis-server --maxmemory-policy noeviction
HealthCmd=redis-cli ping | grep PONG
HealthStartPeriod=20s
HealthInterval=30s
HealthRetries=5
HealthTimeout=3s
Pull=missing
EnvironmentFile=%h/.local/share/services/twenty/.env

[Service]
EnvironmentFile=%h/.local/share/services/twenty/.env
Restart=always
RestartSec=5
TimeoutStartSec=300

[Install]
WantedBy=default.target
